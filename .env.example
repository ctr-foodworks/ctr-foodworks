# ─────────────────────────────────────────────────────────────────────────
# Copy to .env.local for local dev. Set the same vars in Vercel → Settings →
# Environment Variables for production. See SETUP.md for step-by-step.
# ─────────────────────────────────────────────────────────────────────────

# Neon Postgres connection string (use the POOLED string from the Neon
# dashboard). The site falls back to static seed events if this is unset.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js session secret. Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# Admin login lives in the database (users table), NOT in env. Create/reset it:
#   npm run admin:create -- "web@ctrfoodworks.com" "your-strong-password"

# Vercel Blob token for image uploads (Vercel → Storage → Blob).
# Locally you can pull it with:  vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=""

# ── Email (Resend) ─────────────────────────────────────────────────────────
# API key from resend.com; MAIL_FROM must be on a verified Resend domain.
RESEND_API_KEY=""
MAIL_FROM="CTR Food Works <notifications@chattahoocheefoodworks.com>"

# Contact-form routing. CONTACT_TO_GENERAL is the catch-all (Partnerships,
# Careers, General). CONTACT_TO_PRESS routes Press inquiries to PR. Optional
# per-category overrides: CONTACT_TO_PARTNERSHIPS, CONTACT_TO_CAREERS.
CONTACT_TO_GENERAL=""
CONTACT_TO_PRESS=""

# Always-notified observers (comma-separated) — receive EVERY inquiry and every
# customer reply, regardless of category. For a COO/GM who wants full oversight.
CONTACT_NOTIFY_TO=""

# ── Inbound reply relay (optional, Model A) ────────────────────────────────
# When set, staff replies to a contact message flow through Resend inbound and
# are captured in the dashboard (thread + "Responded" status). Leave INBOUND_DOMAIN
# empty to disable the relay (contact form then replies straight to the customer).
#   INBOUND_DOMAIN      — the SUBDOMAIN with Resend inbound MX (keep off the apex,
#                         which is Google's mail). e.g. inbound.ctrfoodworks.com
#   RESEND_WEBHOOK_SECRET — signing secret (whsec_…) from the Resend webhook.
#   SUPPORT_FROM        — sender for customer-facing relayed replies (falls back
#                         to MAIL_FROM). Must be on a verified Resend domain.
INBOUND_DOMAIN=""
RESEND_WEBHOOK_SECRET=""
SUPPORT_FROM="CTR Food Works <support@ctrfoodworks.com>"

# Public site URL — used in invite emails for the "Sign in" link.
NEXT_PUBLIC_SITE_URL="https://www.chattahoocheefoodworks.com"
