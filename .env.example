# ─────────────────────────────────────────────────────────────────────────
# Copy to .env.local for local dev. Set the same vars in Vercel → Settings →
# Environment Variables for production. See SETUP.md for step-by-step.
# ─────────────────────────────────────────────────────────────────────────

# Neon Postgres connection string (use the POOLED string from the Neon
# dashboard). The site falls back to static seed events if this is unset.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js session secret. Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# Admin login lives in the database (users table), NOT in env. Create/reset it:
#   npm run admin:create -- "web@ctrfoodworks.com" "your-strong-password"

# Vercel Blob token for image uploads (Vercel → Storage → Blob).
# Locally you can pull it with:  vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=""

# ── Email (Resend) ─────────────────────────────────────────────────────────
# API key from resend.com; MAIL_FROM must be on a verified Resend domain.
RESEND_API_KEY=""
MAIL_FROM="CTR Food Works <notifications@chattahoocheefoodworks.com>"

# Contact-form routing by category (Press→PR, General/Careers→Management,
# Partnerships→Marketing). Set to the team inboxes.
CONTACT_TO_PRESS=""
CONTACT_TO_MANAGEMENT=""
CONTACT_TO_MARKETING=""

# Public site URL — used in invite emails for the "Sign in" link.
NEXT_PUBLIC_SITE_URL="https://www.chattahoocheefoodworks.com"
